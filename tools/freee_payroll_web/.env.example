# Copy this to a local env file or export these variables in your shell.
# Do not commit real storageState, screenshots, credentials, or local maps.

# Playwright storageState saved by:
#   venv/bin/python -m tools.freee_payroll_web.cli login
FREEE_PAYROLL_STORAGE_STATE=tools/freee_payroll_web/.secrets/freee_storage_state.json.enc

# Optional. If omitted, a Fernet key is generated next to the encrypted storageState.
FREEE_PAYROLL_STORAGE_KEY_PATH=tools/freee_payroll_web/.secrets/freee_storage_state.key

# Optional local JSON map when the visible freee company name differs from defaults.
# Shape:
#   {"12350973": {"names": ["おの歯科医院（旧）"]}}
FREEE_PAYROLL_COMPANY_MAP_FILE=tools/freee_payroll_web/company_map.local.json

# Optional CSS selector for the current company name in the freee header.
FREEE_PAYROLL_COMPANY_SELECTOR=

# Optional JSON map of company_id -> 給与計算グループID (payroll_statements URLのパス).
# Defaults already include {"12350973": "1502865"} (おの歯科 旧, 実機確認 2026-06-27).
# Shape: {"12350973": "1502865"}  または  {"12350973": {"group_id": "1502865"}}
FREEE_PAYROLL_GROUP_MAP_FILE=tools/freee_payroll_web/group_map.local.json

# Optional direct payroll URL template if confirmed from the live UI.
# Available placeholders: {company_id}, {group_id}, {year}, {month}
# 既定の直リンク(グループID既知時): https://p.secure.freee.co.jp/payroll_statements#/{group_id}/{year}/{month}
FREEE_PAYROLL_URL_TEMPLATE=

FREEE_PAYROLL_HEADLESS=false
FREEE_PAYROLL_TIMEOUT_MS=30000
FREEE_PAYROLL_SLOW_MO_MS=0
FREEE_PAYROLL_SCREENSHOT_DIR=outputs/freee_payroll_web/screenshots
